# =============================================================================
# Ricette per Pippe — env vars
#
# Le variabili con prefisso PUBLIC_ sono accessibili lato client (Astro/Vite).
# Le altre sono server-only (Netlify Functions).
# =============================================================================

# ---- Newsletter endpoints (Netlify Functions, no più n8n) -------------------
# Path relativi: i form puntano allo stesso dominio del sito.
PUBLIC_NEWSLETTER_SUBSCRIBE_WEBHOOK=/api/subscribe
PUBLIC_UNSUBSCRIBE_WEBHOOK=/api/unsubscribe

# ---- Supabase (publishable, sicura lato client grazie a RLS) ----------------
PUBLIC_SUPABASE_URL=https://ojviekhgdnbiscmisgvs.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YDEpBusID_09aTY2jslZ0g_3cQsaX-a

# =============================================================================
# SERVER-ONLY (Netlify env, mai shippare al browser)
# =============================================================================

# ---- Supabase service_role (bypassa RLS, usata dalle Functions) -------------
# Dashboard Supabase → Settings → API → service_role key (sotto "Project API keys")
SUPABASE_SERVICE_ROLE_KEY=

# ---- Resend (invio email transazionali) -------------------------------------
# Dashboard Resend → API Keys → Create API Key
RESEND_API_KEY=
# Sender. Mentre testi puoi usare "onboarding@resend.dev"; per produzione
# verifica il dominio ricetteperpippe.com su Resend e metti es:
#   RESEND_FROM_EMAIL=hello@ricetteperpippe.com
RESEND_FROM_EMAIL=onboarding@resend.dev

# ---- Token condiviso per /api/send-recipe -----------------------------------
# Endpoint protetto: solo chi conosce questo token può triggerare gli invii.
# Genera un UUID v4 o una stringa lunga e mettila qui + come header Authorization
# nel client che lancia gli invii.
SEND_RECIPE_TOKEN=

# ---- Site URL canonico (usato in unsubscribe link e immagini email) ---------
SITE_URL=https://ricetteperpippe.com
