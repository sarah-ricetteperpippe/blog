# =============================================================================
# Ricette per Pippe — env vars
#
# Le variabili con prefisso PUBLIC_ sono accessibili lato client (Astro/Vite).
# =============================================================================

# ---- Newsletter — webhook n8n (outofscope.app.n8n.cloud) --------------------
# Iscrizione: usare la Production URL del webhook (senza -test) quando il workflow è attivo.
# NB: la URL -test funziona solo con il workflow aperto in n8n in modalità test.
PUBLIC_NEWSLETTER_WEBHOOK=https://outofscope.app.n8n.cloud/webhook/bd4c2a49-e94d-4b4f-83c7-a4db67d4d200

# Disiscrizione: webhook n8n "Newsletter — Unsubscribe".
PUBLIC_UNSUBSCRIBE_WEBHOOK=https://outofscope.app.n8n.cloud/webhook/ba08ad76-563c-483d-8707-bdc81420ca47

# ---- GitHub Action — Send recipe flow ---------------------------------------
# Usata solo dallo script scripts/notify-newsletter.mjs (non lato client).
# Mettila come repo secret su GitHub: Settings → Secrets → Actions → N8N_SEND_RECIPE_WEBHOOK
# N8N_SEND_RECIPE_WEBHOOK=https://outofscope.app.n8n.cloud/webhook/3938b749-6d37-49db-ad96-fdfadad9aa05

# ---- Supabase (views e likes) -----------------------------------------------
PUBLIC_SUPABASE_URL=https://ojviekhgdnbiscmisgvs.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YDEpBusID_09aTY2jslZ0g_3cQsaX-a
