# Newsletter — Subscription webhook (Workflow 1)
# Riceve POST con {nome, email, lang} dal form della homepage.
# Test URL (one-shot, scade dopo ogni Execute workflow):
#   https://ricetteperpippe.app.n8n.cloud/webhook/<id>
# Production URL (workflow attivato):
#   https://ricetteperpippe.app.n8n.cloud/webhook/<id>
#
# Il prefisso PUBLIC_ è obbligatorio per renderla accessibile lato client (Astro/Vite).
PUBLIC_NEWSLETTER_WEBHOOK=https://ricetteperpippe.app.n8n.cloud/webhook/bd4c2a49-e94d-4b4f-83c7-a4db67d4d200

# Newsletter — Unsubscribe webhook (Workflow 3)
# Riceve POST con {token} dal link unsubscribe nelle email di notifica.
# Aggiornare con la URL del nuovo workflow Newsletter — Unsubscribe.
PUBLIC_UNSUBSCRIBE_WEBHOOK=https://ricetteperpippe.app.n8n.cloud/webhook/ba08ad76-563c-483d-8707-bdc81420ca47
