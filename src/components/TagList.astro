---
import { getBlogTagLabel, getBlogTagSlug, normalizeBlogTag } from '../config/tags';
import type { SiteLang } from '../config/taxonomy';
import { slugify } from '../utils/slugify';

export interface Props {
  tags: string[];
  lang: string;
  /** Tag attualmente attivo (per evidenziarlo nella lista). Opzionale. */
  active?: string;
}

const { tags, lang, active } = Astro.props;
const base = (import.meta.env.BASE_URL as string).endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/';
const currentLang = (lang === 'en' || lang === 'fr' || lang === 'it' ? lang : 'it') as SiteLang;
const activeTag = typeof active === 'string' ? normalizeBlogTag(active) : null;
const localizedTags = (tags ?? []).map((tag) => {
  const normalizedTag = normalizeBlogTag(tag);
  return {
    label: getBlogTagLabel(tag, currentLang),
    hrefTag: getBlogTagSlug(tag, currentLang) || slugify(tag),
    isActive: typeof normalizedTag === 'string'
      ? normalizedTag === activeTag
      : tag === active,
  };
});
---

{tags && tags.length > 0 && (
  <div class="tag-list">
    {localizedTags.map((tag) => (
      <a
        href={`${base}${lang}/blog/tag/${tag.hrefTag}/`}
        class={`tag-chip tag-chip--link${tag.isActive ? ' tag-chip--active' : ''}`}
        rel="tag"
      >{tag.label}</a>
    ))}
  </div>
)}

<style>
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tag-chip--link {
    text-decoration: none;
    transition: background-color 0.15s ease, color 0.15s ease, transform 0.15s ease;
  }
  .tag-chip--link:hover {
    transform: translateY(-1px);
  }
  .tag-chip--active {
    font-weight: 700;
  }
</style>
