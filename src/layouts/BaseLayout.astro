---
import '../styles/global.css';
import 'flag-icons/css/flag-icons.min.css';
import Search from 'astro-pagefind/components/Search';

export interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { title, description = "Le migliori ricette per le peggiori pippe in cucina!", lang = 'it' } = Astro.props;
const base = (import.meta.env.BASE_URL as string).endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

const navLabels = {
  it: { blog: 'Blog', guide: 'Guide', chiSono: 'Chi sono', close: 'Chiudi', search: 'Cerca' },
  en: { blog: 'Blog', guide: 'Guides', chiSono: 'About', close: 'Close', search: 'Search' },
  fr: { blog: 'Blog', guide: 'Guides', chiSono: 'À propos', close: 'Fermer', search: 'Chercher' },
} as const;

const t = navLabels[lang as keyof typeof navLabels] ?? navLabels.it;

const footerLabels = {
  it: {
    tagline: "If it's listed, it's tasted by Sarah",
    copyright: `© ${new Date().getFullYear()} by Ricette per pippe di Sarah Lasaracina. Tutti i diritti riservati.`,
  },
  en: {
    tagline: "If it's listed, it's tasted by Sarah",
    copyright: `© ${new Date().getFullYear()} by Ricette per pippe by Sarah Lasaracina. All rights reserved.`,
  },
  fr: {
    tagline: "If it's listed, it's tasted by Sarah",
    copyright: `© ${new Date().getFullYear()} par Ricette per pippe de Sarah Lasaracina. Tous droits réservés.`,
  },
} as const;

const footerT = footerLabels[lang as keyof typeof footerLabels] ?? footerLabels.it;

// flag-icons usa codici ISO 3166-1 alpha-2; per l'inglese usiamo `gb`
// (Gran Bretagna) per coerenza con la bandierina precedente 🇬🇧.
const flags = [
  { code: 'it', flagCode: 'it', label: 'Italiano' },
  { code: 'en', flagCode: 'gb', label: 'English' },
  { code: 'fr', flagCode: 'fr', label: 'Français' },
];

function switchLangUrl(targetLang: string) {
  const withoutBase = Astro.url.pathname.replace(base.replace(/\/$/, ''), '');
  const parts = withoutBase.split('/').filter(Boolean);
  if (parts.length > 0 && ['it', 'en', 'fr'].includes(parts[0])) {
    parts[0] = targetLang;
  } else {
    parts.unshift(targetLang);
  }
  return `${base}${parts.join('/')}/`.replace(/\/+/g, '/');
}
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="color-scheme" content="light" />
  <title>{title} — Ricette per Pippe</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={Astro.url.href} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Ricette per Pippe" />
  <meta property="og:title" content={`${title} — Ricette per Pippe`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:locale" content={lang === 'it' ? 'it_IT' : lang === 'fr' ? 'fr_FR' : 'en_GB'} />
  <meta property="og:image" content={`${Astro.site}images/og-default.png`} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} — Ricette per Pippe`} />
  <meta name="twitter:description" content={description} />

  <!-- Favicon -->
  <link rel="icon" href="/logo-pippe.png" type="image/png" />
  <link rel="apple-touch-icon" href="/logo-pippe.png" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;1,9..144,400&family=Wix+Madefor+Display:wght@400;500;600&family=Wix+Madefor+Text:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>

  <header class="site-header">
    <div class="site-branding">
      <a href={`${base}${lang}/`} class="site-logo-link" aria-label="Ricette per Pippe - Home">
        <img src={`${base}logo-pippe.png`} alt="Ricette per Pippe" class="site-logo" />
      </a>
      <div class="site-brand-text">
        <span class="site-title site-title-fallback">Ricette per Pippe</span>
        <span class="site-tagline">...if it's listed, it's tasted!</span>
      </div>
    </div>
    <div class="header-right">
      <nav class="header-nav">
        <a href={`${base}${lang}/blog/`}>{t.blog}</a>
        <a href={`${base}${lang}/guide/`}>{t.guide}</a>
        <a href={`${base}${lang}/chi-sono/`}>{t.chiSono}</a>
      </nav>
      <button class="search-trigger" id="search-trigger" aria-label={t.search}>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>
      <div class="lang-switcher">
        {flags.map(({ code, flagCode, label }) => (
          <a
            href={switchLangUrl(code)}
            class={`lang-flag ${lang === code ? 'lang-flag--active' : ''}`}
            title={label}
            aria-label={label}
          >
            <span class={`fi fi-${flagCode}`} aria-hidden="true"></span>
          </a>
        ))}
      </div>
    </div>
  </header>

  <!-- Search Modal -->
  <div class="search-modal" id="search-modal" aria-hidden="true">
    <div class="search-modal-backdrop" id="search-modal-backdrop"></div>
    <div class="search-modal-panel">
      <div class="search-modal-topbar">
        <button class="search-modal-close" id="search-modal-close">{t.close}</button>
      </div>
      <Search id="search" className="pagefind-ui pagefind-modal-ui" uiOptions={{ showImages: true }} />
    </div>
  </div>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="footer-branding" aria-label="Ricette per Pippe">
      <span class="footer-brand-name">Ricette per pippe</span>
      <span class="footer-tagline">{footerT.tagline}</span>
    </div>
    <span class="footer-copyright">{footerT.copyright}</span>
  </footer>

  <script>
    const trigger = document.getElementById('search-trigger');
    const modal = document.getElementById('search-modal');
    const backdrop = document.getElementById('search-modal-backdrop');
    const closeBtn = document.getElementById('search-modal-close');

    function openModal() {
      modal?.classList.add('is-open');
      modal?.removeAttribute('aria-hidden');
      document.body.style.overflow = 'hidden';
      setTimeout(() => {
        const input = modal?.querySelector('input[type="text"]') as HTMLInputElement;
        input?.focus();
      }, 80);
    }

    function closeModal() {
      modal?.classList.remove('is-open');
      modal?.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    trigger?.addEventListener('click', openModal);
    backdrop?.addEventListener('click', closeModal);
    closeBtn?.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeModal();
    });

    // Reveal-on-scroll: fade-up per qualsiasi elemento con classe .js-reveal.
    // Stagger automatico per gruppi: ogni elemento riceve --reveal-idx in
    // base alla sua posizione tra i siblings con la stessa classe.
    {
      const revealEls = Array.from(document.querySelectorAll<HTMLElement>('.js-reveal'));

      // Calcola stagger: indice progressivo solo all'interno di un gruppo
      // (siblings consecutivi con .js-reveal). Reset quando si cambia parent
      // o quando si esce dal "blocco" di card.
      const groups = new Map<HTMLElement, HTMLElement[]>();
      for (const el of revealEls) {
        const parent = el.parentElement ?? document.body;
        if (!groups.has(parent)) groups.set(parent, []);
        groups.get(parent)!.push(el);
      }
      for (const siblings of groups.values()) {
        siblings.forEach((el, i) => {
          // cap a 8 così l'ottavo non aspetta mezzo secondo
          el.style.setProperty('--reveal-idx', String(Math.min(i, 8)));
        });
      }

      const observer = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        }
      }, {
        rootMargin: '0px 0px -8% 0px',
        threshold: 0.05,
      });

      for (const el of revealEls) {
        observer.observe(el);
      }
    }

    // Parallax: per ogni .js-parallax, sposta l'<img> figlia in base alla
    // posizione di scroll. L'immagine è alta 130% del container; la trasli
    // tra -15% e +15% per dare l'effetto "stretch" mentre passi davanti.
    {
      const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduced) {
        const containers = Array.from(document.querySelectorAll<HTMLElement>('.js-parallax'));
        let raf = 0;

        const update = () => {
          raf = 0;
          const winH = window.innerHeight;
          for (const container of containers) {
            const img = container.querySelector<HTMLImageElement>('img');
            if (!img) continue;
            const rect = container.getBoundingClientRect();
            if (rect.bottom < -100 || rect.top > winH + 100) continue;
            // progress 0 → 1 mentre il container attraversa il viewport
            const progress = (winH - rect.top) / (winH + rect.height);
            const clamped = Math.max(0, Math.min(1, progress));
            // translateY: ±20% (range 40% dell'altezza container)
            const offsetPct = (0.5 - clamped) * 40;
            // scale: cresce da 1.0 (entering dal basso) a 1.18 (exit dall'alto)
            // — l'immagine si "espande" continuamente mentre scorri il banner
            const scale = 1 + clamped * 0.18;
            img.style.transform = `translate3d(0, ${offsetPct}%, 0) scale(${scale.toFixed(3)})`;
          }
        };

        const onScroll = () => {
          if (!raf) raf = requestAnimationFrame(update);
        };

        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onScroll);
        update();
      }
    }
  </script>

</body>
</html>
