---
import '../styles/global.css';
import Search from 'astro-pagefind/components/Search';

export interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { title, description = "Le migliori ricette per le peggiori pippe in cucina!", lang = 'it' } = Astro.props;
const base = (import.meta.env.BASE_URL as string).endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

const navLabels = {
  it: { blog: 'Blog', guide: 'Guide', chiSono: 'Chi sono', close: 'Chiudi', search: 'Cerca' },
  en: { blog: 'Blog', guide: 'Guides', chiSono: 'About', close: 'Close', search: 'Search' },
  fr: { blog: 'Blog', guide: 'Guides', chiSono: 'À propos', close: 'Fermer', search: 'Chercher' },
} as const;

const t = navLabels[lang as keyof typeof navLabels] ?? navLabels.it;

const flags = [
  { code: 'it', flag: '🇮🇹', label: 'Italiano' },
  { code: 'en', flag: '🇬🇧', label: 'English' },
  { code: 'fr', flag: '🇫🇷', label: 'Français' },
];

function switchLangUrl(targetLang: string) {
  const withoutBase = Astro.url.pathname.replace(base.replace(/\/$/, ''), '');
  const parts = withoutBase.split('/').filter(Boolean);
  if (parts.length > 0 && ['it', 'en', 'fr'].includes(parts[0])) {
    parts[0] = targetLang;
  } else {
    parts.unshift(targetLang);
  }
  return `${base}${parts.join('/')}/`.replace(/\/+/g, '/');
}
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="color-scheme" content="light" />
  <title>{title} — Ricette per Pippe</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={Astro.url.href} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Ricette per Pippe" />
  <meta property="og:title" content={`${title} — Ricette per Pippe`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:locale" content={lang === 'it' ? 'it_IT' : lang === 'fr' ? 'fr_FR' : 'en_GB'} />
  <meta property="og:image" content={`${Astro.site}images/og-default.png`} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${title} — Ricette per Pippe`} />
  <meta name="twitter:description" content={description} />

  <!-- Favicon -->
  <link rel="icon" href="/logo-pippe.png" type="image/png" />
  <link rel="apple-touch-icon" href="/logo-pippe.png" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;1,9..144,400&display=swap" rel="stylesheet" />
</head>
<body>

  <header class="site-header">
    <div class="site-branding">
      <a href={`${base}${lang}/`} class="site-logo-link" aria-label="Ricette per Pippe - Home">
        <img src={`${base}logo-pippe.png`} alt="Ricette per Pippe" class="site-logo" />
      </a>
      <div class="site-brand-text">
        <span class="site-title site-title-fallback">Ricette per Pippe</span>
        <span class="site-tagline">...if it's listed, it's tasted!</span>
      </div>
    </div>
    <div class="header-right">
      <nav class="header-nav">
        <a href={`${base}${lang}/blog/`}>{t.blog}</a>
        <a href={`${base}${lang}/guide/`}>{t.guide}</a>
        <a href={`${base}${lang}/chi-sono/`}>{t.chiSono}</a>
      </nav>
      <button class="search-trigger" id="search-trigger" aria-label={t.search}>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>
      <div class="lang-switcher">
        {flags.map(({ code, flag, label }) => (
          <a
            href={switchLangUrl(code)}
            class={`lang-flag ${lang === code ? 'lang-flag--active' : ''}`}
            title={label}
            aria-label={label}
          >
            {flag}
          </a>
        ))}
      </div>
    </div>
  </header>

  <!-- Search Modal -->
  <div class="search-modal" id="search-modal" aria-hidden="true">
    <div class="search-modal-backdrop" id="search-modal-backdrop"></div>
    <div class="search-modal-panel">
      <div class="search-modal-topbar">
        <button class="search-modal-close" id="search-modal-close">{t.close}</button>
      </div>
      <Search id="search" className="pagefind-ui pagefind-modal-ui" uiOptions={{ showImages: true }} />
    </div>
  </div>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <span class="footer-tagline">Ricette per Pippe — cucina senza paura</span>
    <span class="footer-copyright">© {new Date().getFullYear()} Sarah Lasaracina</span>
  </footer>

  <script>
    const trigger = document.getElementById('search-trigger');
    const modal = document.getElementById('search-modal');
    const backdrop = document.getElementById('search-modal-backdrop');
    const closeBtn = document.getElementById('search-modal-close');

    function openModal() {
      modal?.classList.add('is-open');
      modal?.removeAttribute('aria-hidden');
      document.body.style.overflow = 'hidden';
      setTimeout(() => {
        const input = modal?.querySelector('input[type="text"]') as HTMLInputElement;
        input?.focus();
      }, 80);
    }

    function closeModal() {
      modal?.classList.remove('is-open');
      modal?.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    trigger?.addEventListener('click', openModal);
    backdrop?.addEventListener('click', closeModal);
    closeBtn?.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeModal();
    });
  </script>

</body>
</html>
