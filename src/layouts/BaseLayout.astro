---
export interface Props {
  title: string;
  description?: string;
}

const { title, description = "Le migliori ricette per le peggiori pippe in cucina!" } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Ricette per Pippe</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Fraunces:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href={`${base}styles/global.css`} />
</head>
<body>

  <header class="site-header">
    <div class="site-branding">
      <a href={base} class="site-title">Ricette per Pippe</a>
      <span class="site-tagline">le migliori ricette per le peggiori pippe in cucina</span>
    </div>
    <nav class="header-nav">
      <a href={base}>Home</a>
      <a href={`${base}ricette/`}>Ricette</a>
      <a href={`${base}blog/`}>Blog</a>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <span class="footer-tagline">Ricette per Pippe — cucina senza paura</span>
    <span class="footer-copyright">© {new Date().getFullYear()} Sarah Lasaracina</span>
  </footer>

</body>
</html>
