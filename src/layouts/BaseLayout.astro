---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { title, description = "Le migliori ricette per le peggiori pippe in cucina!", lang = 'it' } = Astro.props;
const base = (import.meta.env.BASE_URL as string).endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

const navLabels = {
  it: { home: 'Home', blog: 'Blog', recipes: 'Ricette' },
  en: { home: 'Home', blog: 'Blog', recipes: 'Recipes' },
  fr: { home: 'Accueil', blog: 'Blog', recipes: 'Recettes' },
} as const;

const t = navLabels[lang as keyof typeof navLabels] ?? navLabels.it;

const flags = [
  { code: 'it', flag: '🇮🇹', label: 'Italiano' },
  { code: 'en', flag: '🇬🇧', label: 'English' },
  { code: 'fr', flag: '🇫🇷', label: 'Français' },
];

// Costruisce l'URL equivalente nella lingua scelta
// (funziona perché tutte le pagine seguono /<lang>/... )
const currentPath = Astro.url.pathname.replace(base, '');
function switchLangUrl(targetLang: string) {
  const withoutBase = Astro.url.pathname.replace(base.replace(/\/$/, ''), '');
  const parts = withoutBase.split('/').filter(Boolean);
  if (parts.length > 0 && ['it', 'en', 'fr'].includes(parts[0])) {
    parts[0] = targetLang;
  } else {
    parts.unshift(targetLang);
  }
  return `${base}${parts.join('/')}/`.replace(/\/+/g, '/');
}
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Ricette per Pippe</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Fraunces:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
</head>
<body>

  <header class="site-header">
    <div class="site-branding">
      <a href={`${base}${lang}/`} class="site-title">Ricette per Pippe</a>
      <span class="site-tagline">...if it's listed, it's tasted!</span>
    </div>
    <nav class="header-nav">
      <a href={`${base}${lang}/`}>{t.home}</a>
      <a href={`${base}${lang}/blog/`}>{t.blog}</a>
    </nav>
    <div class="lang-switcher">
      {flags.map(({ code, flag, label }) => (
        <a
          href={switchLangUrl(code)}
          class={`lang-flag ${lang === code ? 'lang-flag--active' : ''}`}
          title={label}
          aria-label={label}
        >
          {flag}
        </a>
      ))}
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <span class="footer-tagline">Ricette per Pippe — cucina senza paura</span>
    <span class="footer-copyright">© {new Date().getFullYear()} Sarah Lasaracina</span>
  </footer>

</body>
</html>
