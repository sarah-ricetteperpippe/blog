---
import { getCollection } from 'astro:content';
import GuideLayout from '../../../layouts/GuideLayout.astro';
import { Figure, Gallery, Pullquote, TwoColumn, Aside } from '../../../components/editorial';

export async function getStaticPaths() {
  const posts = await getCollection('academy');
  return posts.map(post => {
    const [lang, ...rest] = post.id.split('/');
    const slug = rest.join('/').replace(/\.(md|mdx)$/, '');
    return {
      params: { lang, slug },
      props: { post },
    };
  });
}

const { lang, slug } = Astro.params;
const { post } = Astro.props;
const { Content } = await post.render();

// Componenti editoriali auto-iniettati: nei .mdx scrivi <Figure …/> senza importarli.
const editorialComponents = { Figure, Gallery, Pullquote, TwoColumn, Aside };
---

<GuideLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  heroImage={post.data.heroImage}
  category={post.data.category}
  tags={post.data.tags}
  difficulty={post.data.difficulty}
  lang={lang}
  slug={slug}
  body={post.body}
>
  <Content components={editorialComponents} />
</GuideLayout>
