---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return [
    { params: { lang: 'it' } },
    { params: { lang: 'en' } },
    { params: { lang: 'fr' } },
  ];
}

const { lang } = Astro.params;
const base = (import.meta.env.BASE_URL as string).endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(p => p.id.startsWith(`${lang}/`))
  .sort((a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf())
  .slice(0, 8);

const slug = (post: any) => post.id.replace(`${lang}/`, '').replace(/\.md$/, '');

const NEWSLETTER_WEBHOOK = 'https://ricetteperpippe.app.n8n.cloud/webhook-test/bd4c2a49-e94d-4b4f-83c7-a4db67d4d200';

const ui = {
  it: {
    heroTitle: 'Le migliori ricette\nper le peggiori pippe in cucina!',
    heroDesc: 'Benvenuti su <em class="hero-brand">Ricette per pippe</em>,<br>il luogo perfetto per scoprire nuove ricette a prova di incapace, testate e approvate da Sarah.<br>Per pippe in cucina che ambiscono alla mera sopravvivenza,<br>e per tutte quelle che ogni tanto sperano anche di fare (umilmente) figura!',
    cta: 'Scopri di più',
    subscribe: 'Iscriviti',
    latest: 'Ultimi articoli',
    allPosts: 'Tutti gli articoli →',
    marquee: ['Se può farlo una pippa come me, puoi farlo anche tu!'],
    newsletterTitle: 'Ricevi ricettine!',
    newsletterDesc: 'Vuoi che condivida con te quando accade un (più unico che raro) miracolo nella mia cucina?',
    newsletterName: 'Il tuo nome',
    newsletterEmail: 'La tua email',
    newsletterCta: 'Condividi la gioia!',
    newsletterSuccess: '🎉 Ci sei! Controlla la tua casella di posta.',
    newsletterError: 'Qualcosa è andato storto. Riprova tra poco.',
  },
  en: {
    heroTitle: 'The best recipes\nfor the worst cooks in the kitchen!',
    heroDesc: 'Welcome to Ricette per pippe, the perfect place to discover new foolproof recipes, tested and approved by Sarah.',
    cta: 'Discover more',
    subscribe: 'Subscribe',
    latest: 'Latest posts',
    allPosts: 'All posts →',
    marquee: ['If a total klutz like me can do it, so can you!'],
    newsletterTitle: 'Get little recipes!',
    newsletterDesc: 'Want me to share with you when a (rare) kitchen miracle happens?',
    newsletterName: 'Your name',
    newsletterEmail: 'Your email',
    newsletterCta: 'Share the joy!',
    newsletterSuccess: '🎉 You\'re in! Check your inbox.',
    newsletterError: 'Something went wrong. Please try again.',
  },
  fr: {
    heroTitle: 'Les meilleures recettes\npour les pires cuisiniers !',
    heroDesc: 'Bienvenue sur Ricette per pippe, le lieu idéal pour découvrir des recettes simples et infaillibles, testées et approuvées par Sarah.',
    cta: 'Découvrir',
    subscribe: "S'abonner",
    latest: 'Derniers articles',
    allPosts: 'Tous les articles →',
    marquee: ['Si une quiche comme moi peut le faire, vous pouvez le faire aussi !'],
    newsletterTitle: 'Recevez des petites recettes !',
    newsletterDesc: 'Envie que je partage avec vous quand un miracle (rare) se produit dans ma cuisine ?',
    newsletterName: 'Votre prénom',
    newsletterEmail: 'Votre email',
    newsletterCta: 'Partager la joie !',
    newsletterSuccess: '🎉 Vous êtes inscrit·e ! Vérifiez votre boîte mail.',
    newsletterError: 'Une erreur est survenue. Réessayez.',
  },
} as const;

const t = ui[lang as keyof typeof ui] ?? ui.it;
const marqueeItems = [...t.marquee, ...t.marquee, ...t.marquee, ...t.marquee];
---

<BaseLayout title="Home" lang={lang}>

  <section class="hero-section">
    <h1 class="hero-title">{t.heroTitle.split('\n').map((line, i) => <>{line}{i === 0 && <br/>}</>)}</h1>
    <p class="hero-description" set:html={t.heroDesc} />
    <div class="hero-buttons">
      <a href={`${base}${lang}/blog/`} class="btn-primary">{t.cta}</a>
      <a href={`${base}${lang}/blog/`} class="btn-secondary">{t.subscribe}</a>
    </div>
  </section>

  <section class="marquee-section">
    <div class="marquee-inner">
      {marqueeItems.map(item => <span>{item}</span>)}
    </div>
  </section>

  <div class="home-banner">
    <img src={`${base}main-banner.png`} alt="Ricette per pippe" class="home-banner-img" loading="lazy" />
  </div>

  <section class="recipes-section">
    <h2 class="section-title">{t.latest}</h2>
    <div class="recipes-grid">
      {posts.map(post => (
        <article class="recipe-card">
          <a href={`${base}${lang}/blog/${slug(post)}/`} class="recipe-card-link">
            {post.data.heroImage
              ? <img src={post.data.heroImage} alt={post.data.title} class="recipe-card-image" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
              : null
            }
            <div class="recipe-card-placeholder" style={post.data.heroImage ? 'display:none' : ''}>🍳</div>
            <div class="recipe-card-content">
              <h3 class="recipe-card-title">{post.data.title}</h3>
              <p class="recipe-card-excerpt">{post.data.description}</p>
            </div>
          </a>
          <div class="recipe-card-footer">
            <span class="recipe-card-views">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              0
            </span>
            <button class="recipe-like-btn" data-post-id={slug(post)} aria-label="Mi piace">
              <span class="recipe-like-heart">♡</span>
            </button>
          </div>
        </article>
      ))}
    </div>
    <div class="recipes-cta">
      <a href={`${base}${lang}/blog/`} class="btn-primary">{t.allPosts}</a>
    </div>
  </section>

  <section class="newsletter-section">
    <div class="newsletter-inner">
      <div class="newsletter-text">
        <h2 class="newsletter-title">{t.newsletterTitle}</h2>
        <p class="newsletter-desc">{t.newsletterDesc}</p>
      </div>
      <form class="newsletter-form" id="newsletter-form" novalidate>
        <input type="text" name="nome" class="newsletter-input" placeholder={t.newsletterName} required autocomplete="given-name" />
        <input type="email" name="email" class="newsletter-input" placeholder={t.newsletterEmail} required autocomplete="email" />
        <button type="submit" class="newsletter-btn">{t.newsletterCta}</button>
      </form>
      <p class="newsletter-feedback" id="newsletter-feedback" aria-live="polite"></p>
    </div>
  </section>

</BaseLayout>

<script>
  // Like buttons
  document.querySelectorAll<HTMLButtonElement>('.recipe-like-btn').forEach(btn => {
    const id = btn.dataset.postId ?? '';
    const heart = btn.querySelector('.recipe-like-heart') as HTMLElement;
    if (localStorage.getItem(`liked-${id}`) === 'true') {
      btn.classList.add('liked');
      heart.textContent = '♥';
    }
    btn.addEventListener('click', () => {
      const isLiked = btn.classList.toggle('liked');
      heart.textContent = isLiked ? '♥' : '♡';
      localStorage.setItem(`liked-${id}`, String(isLiked));
    });
  });

  // Newsletter form
  const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
  const feedback = document.getElementById('newsletter-feedback') as HTMLElement | null;
  const WEBHOOK = 'https://ricetteperpippe.app.n8n.cloud/webhook-test/bd4c2a49-e94d-4b4f-83c7-a4db67d4d200';
  const MSG_OK = form?.closest('section')?.querySelector('.newsletter-feedback')?.getAttribute('data-ok') ?? '🎉 Ci sei! Controlla la tua casella di posta.';
  const MSG_ERR = '❌ Qualcosa è andato storto. Riprova tra poco.';

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(form));
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = '...';
    try {
      const res = await fetch(WEBHOOK, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ nome: data.nome, email: data.email, lang: document.documentElement.lang || 'it' }),
      });
      if (res.ok || res.status === 200) {
        form.style.display = 'none';
        if (feedback) { feedback.textContent = MSG_OK; feedback.className = 'newsletter-feedback newsletter-feedback--ok'; }
      } else {
        throw new Error('Non-OK response');
      }
    } catch {
      if (feedback) { feedback.textContent = MSG_ERR; feedback.className = 'newsletter-feedback newsletter-feedback--err'; }
      btn.disabled = false;
      btn.textContent = 'Condividi la gioia!';
    }
  });
</script>
