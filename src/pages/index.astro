---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
).slice(0, 4);

const base = import.meta.env.BASE_URL;

const marqueeItems = [
  "Pasta al pomodoro", "Tiramisù", "Risotto ai funghi",
  "Pesto genovese", "Cacio e pepe", "Carbonara",
  "Pasta al pomodoro", "Tiramisù", "Risotto ai funghi",
  "Pesto genovese", "Cacio e pepe", "Carbonara",
];
---

<BaseLayout title="Home">

  <!-- Hero -->
  <section class="hero-section">
    <h1 class="hero-title">Ricette per Pippe</h1>
    <p class="hero-description">
      Le migliori ricette per le peggiori pippe in cucina.<br />
      <strong>Cucina senza paura — anche se sei una pippa!</strong>
    </p>
    <div class="hero-buttons">
      <a href={`${base}ricette/`} class="btn-primary">Vedi le Ricette</a>
      <a href={`${base}blog/`} class="btn-secondary">Leggi il Blog</a>
    </div>
  </section>

  <!-- Marquee -->
  <section class="marquee-section">
    <div class="marquee-inner">
      {marqueeItems.map(item => <span>{item}</span>)}
    </div>
  </section>

  <!-- Ultimi Post -->
  <section class="recipes-section">
    <h2 class="section-title">Ultimi articoli</h2>
    <div class="recipes-grid">
      {posts.map(post => (
        <a href={`${base}blog/${post.slug}/`} class="recipe-card">
          {post.data.heroImage && (
            <img src={post.data.heroImage} alt={post.data.title} />
          )}
          <div class="recipe-card-content">
            <h3 class="recipe-card-title">{post.data.title}</h3>
            <p class="recipe-card-excerpt">{post.data.description}</p>
          </div>
        </a>
      ))}
    </div>
    <div class="recipes-cta">
      <a href={`${base}blog/`} class="btn-primary">Tutti gli articoli →</a>
    </div>
  </section>

</BaseLayout>
